# ── IndexTTS2 服务配置 ──────────────────────────────────────────────
# 使用方式：cp .env.example .env，然后填写实际值
# 警告：.env 文件已加入 .gitignore，禁止提交到 git

# API 密钥（必填，建议使用强随机字符串，如：openssl rand -hex 32）
TTS_API_KEY=your-secret-key-here-change-me

# 服务配置
HOST=0.0.0.0
PORT=8000

# 模型配置
USE_FP16=true          # RTX 3080 Ti 支持 FP16，强烈建议开启（显存减半，速度提升）
MAX_QUEUE_DEPTH=5      # 最大排队深度，超出返回 429（根据 GPU 性能调整）

# 模型权重路径（WSL2 原生文件系统，性能最好）
# 如果你的用户名不是 root，改为 /home/你的用户名/tts-checkpoints
CHECKPOINTS_HOST_PATH=/root/tts-checkpoints

# 音频缓存（对重复文本有效，减少 GPU 重复推理）
ENABLE_CACHE=true
